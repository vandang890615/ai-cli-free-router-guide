# Copy this file to .env locally.
# Never commit real API keys.

# OpenAI-compatible routers/providers
OPENROUTER_API_KEY="sk-or-v1-REPLACE_ME"
NVIDIA_API_KEY="nvapi-REPLACE_ME"
GEMINI_API_KEY="AIzaSyREPLACE_ME"

# Claude Code compatible proxy token
ANTHROPIC_API_KEY="REPLACE_ME"
ANTHROPIC_BASE_URL="https://cc.freemodel.dev"
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1"

# FreeLLMAPI local proxy
FREELLMAPI_BASE_URL="http://127.0.0.1:3001/v1"
FREELLMAPI_API_KEY="freellmapi-REPLACE_ME"

# LM Studio local OpenAI-compatible API
LMSTUDIO_BASE_URL="http://127.0.0.1:1234/v1"
LMSTUDIO_API_KEY="lm-studio"
LMSTUDIO_MODEL="qwen3-14b-q5"

# GitHub Copilot CLI BYOK/local provider example
COPILOT_PROVIDER_BASE_URL="http://127.0.0.1:1234/v1"
COPILOT_PROVIDER_TYPE="openai"
COPILOT_PROVIDER_API_KEY="lm-studio"
COPILOT_MODEL="qwen3-14b-q5"

# free-claude-code local proxy
FREE_CLAUDE_CODE_BASE_URL="http://127.0.0.1:8082"
FREE_CLAUDE_CODE_AUTH_TOKEN="freecc"
